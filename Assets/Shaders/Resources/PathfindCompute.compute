#pragma kernel WavefrontExpand
#pragma kernel GoalDetect
#pragma kernel Reset

#define INF 999999.0
#define STATE_UNREACHED 0
#define STATE_FRONTIER 1
#define STATE_VISITED 2

struct PathNode
{
    float cost;
    int state;
    int parent;
    int padding;
};

struct NeighborData
{
    int neighbors[6];
};

StructuredBuffer<NeighborData> neighbors;
StructuredBuffer<PathNode> pathDataIn;
RWStructuredBuffer<PathNode> pathDataOut;
RWStructuredBuffer<int> goalResult;

int nodeCount;
int goalIndex;
int startIndex;

[numthreads(64,1,1)]
void WavefrontExpand (uint3 id : SV_DispatchThreadID)
{
    int idx = (int)id.x;
    if (idx >= nodeCount) return;

    PathNode my = pathDataIn[idx];

    if (my.state == STATE_VISITED)
    {
        pathDataOut[idx] = my;
        return;
    }

    if (my.state == STATE_FRONTIER)
    {
        PathNode result;
        result.cost = my.cost;
        result.state = STATE_VISITED;
        result.parent = my.parent;
        result.padding = 0;
        pathDataOut[idx] = result;
        return;
    }

    NeighborData nbr = neighbors[idx];
    float bestCost = INF;
    int bestParent = -1;

    for (int i = 0; i < 6; i++)
    {
        int nIdx = nbr.neighbors[i];
        if (nIdx < 0) continue;
        PathNode nd = pathDataIn[nIdx];
        if (nd.state != STATE_FRONTIER) continue;
        float newCost = nd.cost + 1.0;
        if (newCost < bestCost)
        {
            bestCost = newCost;
            bestParent = nIdx;
        }
    }

    PathNode result;
    if (bestCost < INF)
    {
        result.cost = bestCost;
        result.state = STATE_FRONTIER;
        result.parent = bestParent;
    }
    else
    {
        result.cost = INF;
        result.state = STATE_UNREACHED;
        result.parent = -1;
    }
    result.padding = 0;
    pathDataOut[idx] = result;
}

[numthreads(1,1,1)]
void GoalDetect (uint3 id : SV_DispatchThreadID)
{
    PathNode goal = pathDataIn[goalIndex];
    goalResult[0] = (goal.state >= STATE_VISITED) ? 1 : 0;
}

[numthreads(64,1,1)]
void Reset (uint3 id : SV_DispatchThreadID)
{
    int idx = (int)id.x;
    if (idx >= nodeCount) return;

    PathNode node;
    if (idx == startIndex)
    {
        node.cost = 0.0;
        node.state = STATE_FRONTIER;
        node.parent = -1;
    }
    else
    {
        node.cost = INF;
        node.state = STATE_UNREACHED;
        node.parent = -1;
    }
    node.padding = 0;
    pathDataOut[idx] = node;
}